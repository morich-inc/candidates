.csl::after{content:'';flex:1;height:1px;background:var(--red-mid);}
.chips{display:flex;flex-wrap:wrap;gap:7px;}
.chip{background:var(--rose);border:1px solid var(--border);border-radius:7px;padding:7px 11px;font-size:12px;}
.chip-l{color:var(--text-light);font-size:10px;margin-bottom:2px;}.chip-v{font-weight:500;color:var(--text);}
.career-list,.alist{display:flex;flex-direction:column;gap:5px;}
.crow{display:flex;gap:8px;align-items:flex-start;font-size:12.5px;line-height:1.6;}
.cdot{width:5px;height:5px;border-radius:50%;background:var(--red-mid);flex-shrink:0;margin-top:7px;}
.aitem{background:var(--rose);border-left:3px solid var(--red);border-radius:0 7px 7px 0;padding:8px 11px;font-size:12.5px;line-height:1.6;}
.schips{display:flex;flex-wrap:wrap;gap:5px;}
