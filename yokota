.rbox{background:var(--rose);border-radius:9px;padding:13px;border:1px solid var(--bsoft);}
.rsbox{background:#fff;border-radius:9px;padding:13px;border:1px solid var(--border);}
.rbox p,.rsbox p{font-size:12.5px;line-height:1.85;color:var(--text);}
.cdiv{border:none;border-top:1px solid var(--bsoft);margin:13px 0;}
